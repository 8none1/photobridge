# ============================================================
# WhatsApp Cloud API (Meta)
# https://developers.facebook.com/docs/whatsapp/cloud-api
# ============================================================
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_VERIFY_TOKEN=a_random_string_you_choose_for_webhook_verification
# Found in: Meta App Dashboard → App Settings → Basic → App Secret
WHATSAPP_APP_SECRET=your_meta_app_secret_here

# ============================================================
# WordPress
# Generate via: WordPress Admin → Users → Profile → Application Passwords
# ============================================================
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_USERNAME=your_wp_username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ============================================================
# Google Drive
# Service account JSON key — do NOT commit this file
# Store the path here for local dev; in production use Secret Manager
# ============================================================
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account.json
GOOGLE_DRIVE_FOLDER_ID=your_target_folder_id_here

# ============================================================
# Instagram
# Requires an Instagram Business or Creator account linked to a Facebook Page.
# Token needs: instagram_basic, instagram_content_publish permissions.
# https://developers.facebook.com/docs/instagram-api/guides/content-publishing
# ============================================================
INSTAGRAM_USER_ID=your_instagram_business_user_id
INSTAGRAM_ACCESS_TOKEN=your_long_lived_user_access_token

# ============================================================
# Plugin configuration
#
# Each plugin can be toggled on/off and optionally restricted to
# only fire when the photo caption contains a specific tag.
#
# PLUGIN_<NAME>_ENABLED      true/false   default: true
# PLUGIN_<NAME>_REQUIRE_TAG  true/false   default: false (process all photos)
# PLUGIN_<NAME>_TAG          hashtag      default: #<name>
#
# Example: only post to Instagram when caption contains #instagram
#   PLUGIN_INSTAGRAM_REQUIRE_TAG=true
#   PLUGIN_INSTAGRAM_TAG=#instagram
# ============================================================
PLUGIN_WORDPRESS_ENABLED=true
PLUGIN_WORDPRESS_REQUIRE_TAG=false
PLUGIN_WORDPRESS_TAG=#wordpress

PLUGIN_DRIVE_ENABLED=true
PLUGIN_DRIVE_REQUIRE_TAG=false
PLUGIN_DRIVE_TAG=#drive

PLUGIN_INSTAGRAM_ENABLED=true
PLUGIN_INSTAGRAM_REQUIRE_TAG=false
PLUGIN_INSTAGRAM_TAG=#instagram

# ============================================================
# Google Cloud (production only)
# ============================================================
GCP_PROJECT_ID=your-gcp-project-id
# Set to "true" in Cloud Run/Functions to use Secret Manager instead of env vars
USE_SECRET_MANAGER=false
